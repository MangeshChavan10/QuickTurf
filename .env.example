# QuickTurf – Environment Variables
# Copy this file to .env and fill in your values.
# ⚠️  NEVER commit the actual .env file to GitHub.

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Get your connection string from MongoDB Atlas → Connect → Drivers
MONGODB_URI=""

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# A long random string; generate with: openssl rand -hex 32
JWT_SECRET=""

# ── Razorpay Payments ─────────────────────────────────────────────────────────
# Create keys at https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Set this in Razorpay Dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=""

# ── SMTP (Email) ──────────────────────────────────────────────────────────────
# For Gmail: enable 2FA and create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
